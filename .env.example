# Required environment variables

# MongoDB connection string
# Development (local MongoDB or Docker): mongodb://localhost:27017/agents-gallery
# Production (Docker Compose): mongodb://mongodb:27017/agents-gallery
MONGODB_URI=mongodb://localhost:27017/agents-gallery

# 阿里云百炼 API Key
DASHSCOPE_API_KEY=your-api-key-here

# Optional: Docker registry for pushing images
# REGISTRY=your-registry.com

# Public URL for file uploads (required for 百炼 file问答)
# Example: https://your-domain.com or http://your-ip:3000
PUBLIC_URL=
